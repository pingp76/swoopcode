# ============================================================
# LLM Provider 配置
# ============================================================

# Provider 标识（可选）。系统会根据 LLM_BASE_URL 自动推断，
# 只有在使用自定义代理或非标准端点时才需要显式设置。
# 可选值：openai_compatible, minimax_cn, kimi_platform_cn, kimi_code_cn
#
# 常用组合（选一种即可）：
# ┌─────────────────────┬──────────────────────────────┬────────────────────────┐
# │ 用途                │ 推荐配置                     │ 说明                   │
# ├─────────────────────┼──────────────────────────────┼────────────────────────┤
# │ Kimi Code CN        │ LLM_BASE_URL + LLM_API_KEY   │ 自动推断为 kimi_code_cn│
# │                     │ (无需写 LLM_PROVIDER)        │ 自动启用 streaming     │
# │ Kimi Platform CN    │ LLM_PROVIDER=kimi_platform_cn│ 普通 Moonshot 开放平台 │
# │                     │ + MOONSHOT_API_KEY           │                        │
# │ MiniMax CN          │ LLM_PROVIDER=minimax_cn      │ 国内 MiniMax 接口      │
# │                     │ + MINIMAX_CN_API_KEY         │                        │
# │ 自定义 OpenAI 接口  │ LLM_BASE_URL + LLM_API_KEY   │ 自动推断为             │
# │                     │ + LLM_MODEL                  │ openai_compatible      │
# └─────────────────────┴──────────────────────────────┴────────────────────────┘
#
# 优先级：LLM_API_KEY > 各 provider 专用 key
# 通用变量（LLM_API_KEY / LLM_BASE_URL / LLM_MODEL）始终优先于 provider 默认值。
# LLM_PROVIDER=kimi_code_cn

# 通用 API 密钥（所有 provider 都支持，优先级最高）
LLM_API_KEY=your-api-key-here

# API 基础 URL（覆盖 provider 默认值，也可用于触发自动推断）
# Kimi Code CN:       https://api.kimi.com/coding/v1
# Kimi Platform CN:   https://api.moonshot.cn/v1
# MiniMax CN:         https://api.minimaxi.com/v1
LLM_BASE_URL=https://api.minimaxi.com/v1

# 模型名称（覆盖 provider 默认值）
# Kimi Code CN 默认:       kimi-for-coding
# Kimi Platform CN 默认:   kimi-k2.6
# MiniMax CN 默认:         MiniMax-M2.7
LLM_MODEL=MiniMax-M2.7

# Provider 专用 key（当 LLM_API_KEY 未设置时作为 fallback）
# KIMI_CODE_API_KEY=sk-kimi-...
# MOONSHOT_API_KEY=sk-moonshot-...
# MINIMAX_CN_API_KEY=sk-minimax-...
# MINIMAX_API_KEY=sk-minimax-...

# ============================================================
# 日志与压缩配置（不配置则使用默认值）
# ============================================================
LOG_LEVEL=info

# 上下文压缩配置
# COMPRESS_TOOL_OUTPUT=2000
# COMPRESS_DECAY_THRESHOLD=3
# COMPRESS_DECAY_PREVIEW=100
# COMPRESS_MAX_CONTEXT=80000
# COMPACT_KEEP_RECENT=4
